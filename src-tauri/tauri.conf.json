{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VinteEnterprise",
  "version": "0.2.7",
  "identifier": "com.vinteenterprise",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "VinteEnterprise",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "http://localhost:1420/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dangerousInsecureTransportProtocol": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4NThCRDg2MzNGMTlERTEKUldUaG5mRXpocjFZaUFyUWVQQlhCRUxZWXJhakJIZSsrVVhFc3VucC9TRThUSno3RURzaWZLWEgK"
    }
  }
}
